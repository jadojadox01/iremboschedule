{
  "name": "irembo-schedule-availability-monitor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "dev": "node scripts/devWithWorker.js",
    "next:dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "scan": "node worker/scheduler.js --once",
    "worker": "node worker/scheduler.js"
  },
  "dependencies": {
    "@prisma/client": "6.10.1",
    "axios": "1.10.0",
    "next": "15.3.4",
    "prisma": "6.10.1",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.10",
    "tailwindcss": "4.1.10"
  }
}
